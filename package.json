{
  "name": "oops-framework",
  "version": "0.1.0",
  "description": "OOPS Framework - TDD enforcement for LLM-driven development via Claude Code Hooks",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "tdd",
    "claude",
    "claude-code",
    "hooks",
    "llm",
    "ai",
    "testing",
    "red-green-refactor"
  ],
  "bin": {
    "oops": "./bin/oops"
  },
  "files": [
    "bin/",
    "src/",
    ".claude/hooks/",
    ".claude/skills/",
    ".oops/config.json",
    ".oops/README.md",
    "tsconfig.json"
  ],
  "scripts": {
