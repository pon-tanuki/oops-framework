    "test": "jest test-files/",
    "test:oops": "npx tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jest": "^30.2.0",
    "typescript": "^5.7.0"
  }
}
